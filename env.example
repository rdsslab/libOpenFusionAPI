# Copy this file to .env and adjust the values for your environment.
# .env is git-ignored; this file (.env.example) is committed as a reference template.

# --- Server ---
PORT=3000
HOST=localhost
NODE_ENV=development

# --- Auth ---
# Secret used to sign/verify JWTs. Required in production: the process exits on boot
# if this is unset and NODE_ENV=production. In development, an insecure fallback key
# is used with a console warning if left unset.
JWT_KEY=change-me-to-a-strong-random-secret

# --- App functions ---
# Filesystem path where custom app function files live.
PATH_APP_FUNCTIONS=src/fn

# --- Uploads ---
# Max multipart upload size, in MB.
MAX_FILE_SIZE_UPLOAD=100

# --- Database (Sequelize) ---
# DATABASE_URL takes precedence over DATABASE_URI_API. If neither is set, the app
# falls back to a local sqlite file in the OS temp directory.
#DATABASE_URL=postgres://user:password@host:5432/dbname
#DATABASE_URI_API=postgres://user:password@host:5432/dbname
# Enable Heroku-style Postgres SSL options (rejectUnauthorized: false).
#USE_HEROKU_POSTGRESQL=true
# Prefix applied to all database table names.
#TABLE_NAME_PREFIX_API=
# Rebuild/seed the database on boot.
#BUILD_DB=true

# --- SQL handler tuning ---
# Idle-time threshold (ms) before validating a pooled SQL connection.
#OFAPI_SQL_POOL_VALIDATE_IDLE_MS=30000
# Force SQL pool connection validation on every use instead of only after idle timeout.
#OFAPI_SQL_POOL_FORCE_VALIDATE_ALWAYS=false
# Enable live (non-cached) reads of App Vars in the SQL handler.
#OFAPI_APPVARS_LIVE_READ=false

# --- JWT clock sync (host clock drift correction) ---
# Disabled by default. Enable only if the host's system clock cannot be trusted
# (e.g. misconfigured RTC causing a fixed offset). When enabled, the app periodically
# checks an external time source and, if the drift exceeds 5 minutes, uses the
# corrected time to sign/verify JWTs (iat/exp/nbf) instead of the raw system clock.
TIME_SYNC_ENABLED=false
