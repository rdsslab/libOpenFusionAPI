{
  "name": "@rdsslab/libopenfusionapi",
  "version": "6.5.7",
  "description": "Library based on Fastify to create APIs quickly and easily from a web interface.",
  "scripts": {
    "test": "node ./dev/test/index.js",
    "test:cache": "node ./dev/test/cache_validation.js",
    "test:ws-cache-events": "node ./dev/test/ws_cache_events.js",
    "test:owasp": "node ./dev/test/owasp_top10.js",
    "test:mcp-docs": "node ./dev/test/mcp_tool_descriptions.js",
    "test:mcp-names": "node ./dev/scratch/check_mcp_name_uniqueness.js --server-key openfusion_system_remote_prd --app system --environment prd --idapp cfcd2084-95d5-65ef-66e7-dff9f98764da",
    "test:smoke": "node ./dev/test/smoke_runtime.js",
    "system:check": "node ./scripts/system_sync.mjs --check-only",
    "system:sync": "node ./scripts/system_sync.mjs",
    "docs:js-api": "node ./src/lib/server/generateDocs.js",
    "docs:handlers:index": "node ./src/lib/server/generateHandlerIndex.js",
    "docs:handlers:validate": "node ./src/lib/server/validateHandlerDocs.js",
    "docs:handlers": "npm run docs:js-api && npm run docs:handlers:index && npm run docs:handlers:validate",
    "set_version": "node ./set_version.js",
    "start": "node --max-old-space-size=4096 ./src/server.js",
    "test:integration": "node ./dev/test/integration_test.js",
    "test:fetch-timeout": "node ./dev/test/fetch_timeout_test.js",
    "test:all": "node ./dev/test/index.js",
    "reinstall": "rm -rf node_modules package-lock.json && npm install"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rdsslab/libOpenFusionAPI.git"
  },
  "main": "index.js",
  "keywords": [
    "Node",
    "javascript",
    "API",
    "OpenFusionAPI",
    "edwinspire",
    "SQL",
    "SOAP",
    "Websocket",
    "rdsslab"
  ],
  "author": "edwinspire <edwinspire@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rdsslab/libOpenFusionAPI/issues"
  },
  "homepage": "https://github.com/rdsslab/libOpenFusionAPI#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.48.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@rdsslab/sequential-promises": "git+https://github.com/rdsslab/sequential-promises.git",
    "@rdsslab/uFetch": "git+https://github.com/rdsslab/uFetch.git",
    "@sap/hana-client": "^2.22.32",
    "@sparticuz/chromium": "^141.0.0",
    "@xmldom/xmldom": "^0.9.9",
    "ajv": "^8.12.0",
    "chrome-launcher": "^1.2.1",
    "dotenv": "^16.3.1",
    "fastify": "^5.7.4",
    "grammy": "^1.39.3",
    "jsonwebtoken": "^9.0.0",
    "luxon": "^3.5.0",
    "mariadb": "^3.2.2",
    "mongoose": "^8.9.5",
    "mongose": "^0.0.2-security",
    "mysql2": "^3.6.3",
    "node-forge": "^1.3.3",
    "nodemailer": "^9.0.3",
    "object-hash": "^3.0.0",
    "openai": "^6.18.0",
    "oracledb": "^6.2.0",
    "path-to-regexp": "^6.2.1",
    "pdfjs-dist": "^5.4.394",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.31.0",
    "puppeteer-core": "^24.31.0",
    "sequelize": "^6.37.8",
    "soap": "^1.8.0",
    "sqlite3": "^6.0.1",
    "systeminformation": "^5.27.11",
    "tedious": "^16.6.0",
    "uuid": "^14.0.1",
    "vm": "^0.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xlsx-js-style": "^1.2.0",
    "xml-crypto": "^6.1.2",
    "xml-formatter": "^3.6.7",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  },
  "overrides": {
    "@azure/identity": ">=4.2.1",
    "minimatch": ">=10.2.1",
    "tar": ">=7.5.8",
    "sequelize": {
      "uuid": "^11.1.1"
    }
  }
}
